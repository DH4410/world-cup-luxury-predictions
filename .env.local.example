# Copy to .env.local for local dev (Vite reads this automatically, it's gitignored).
# For production (Vercel / Cloudflare Pages) set these as environment variables in the dashboard.

# Auth server — where the login/signup/logout endpoints live
VITE_AUTH_URL=http://localhost:5420

# Game server — predictions, rooms, leaderboard, match data
VITE_GAME_URL=http://localhost:5421

# WebSocket URL — must point to the same game server
VITE_WS_URL=ws://localhost:5421

# --- Production example (uncomment and update when domain is live) ---
# VITE_AUTH_URL=https://auth.yourdomain.com
# VITE_GAME_URL=https://api.yourdomain.com
# VITE_WS_URL=wss://api.yourdomain.com
