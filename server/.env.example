# Copy this to server/.env and fill in real values before running on the Pi.
# Both servers read from this single file (../server/.env relative to each server dir).

# Shared secret for JWT signing — must be the same on both servers
JWT_SECRET=change-me-to-a-long-random-secret

# Password to access the /dev admin panel (in the client, POSTed to /dev/api/login)
ADMIN_PASSWORD=change-me-admin-password

# Directory where SQLite databases and leaderboard.json are stored.
# Keep this OUTSIDE the repo so git pull never wipes your data.
# Pi example: DATA_DIR=/home/pi/world-cup-data
DATA_DIR=./data

# Port each server listens on locally (Cloudflare Tunnel forwards these)
AUTH_PORT=5420
GAME_PORT=5421

# Origin of the frontend (used for CORS + cookie validation)
# Dev: CLIENT_ORIGIN=http://localhost:5173
# Prod: CLIENT_ORIGIN=https://yourdomain.com
CLIENT_ORIGIN=http://localhost:5173

# Cookie domain — set to .yourdomain.com in production so cookie is shared across subdomains.
# Leave blank for localhost dev (cookie defaults to current hostname).
COOKIE_DOMAIN=

# Match data polling interval in milliseconds (default: 5 minutes)
POLL_INTERVAL_MS=300000

# Cookie SameSite policy:
#   lax  — use for local dev and production (client + servers share same apex domain). Default.
#   none — use when client is on *.vercel.app / *.pages.dev and servers are on *.trycloudflare.com
#           (cross-site). Both ends must be HTTPS (Cloudflare Tunnel guarantees this).
#           Switch back to 'lax' once your domain is live.
COOKIE_SAMESITE=lax

NODE_ENV=production
